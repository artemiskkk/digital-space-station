---
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
const { slug } = Astro.params;

// Read auth token from cookie (set on login) to access drafts/private posts
const cookieHeader = Astro.request.headers.get('cookie') || '';
const tokenMatch = cookieHeader.match(/dss_token=([^;]+)/);
const token = tokenMatch ? tokenMatch[1] : '';

const headers: Record<string, string> = {};
if (token) headers['Authorization'] = 'Bearer ' + token;

const res = await fetch(`${API_URL}/api/posts/${slug}`, { headers });
if (!res.ok) return Astro.redirect('/blog');
const post = await res.json();
const title = post.title;
const tags = post.tags || [];
const excerpt = post.excerpt || '';
const readTime = post.read_time || '';
const content = post.content || '';
const htmlContent = await marked(content);

const formattedDate = new Date(post.created_at).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} · DSS`} description={excerpt}>

  <div class="article-layout">

  <article class="article-main">

    <!-- ── 返回按钮 ────────────────────────────────────────── -->
    <a
      href="/blog"
      class="inline-flex items-center gap-2 text-xs transition-colors duration-300 tracking-widest mb-14 group"
      style="font-family: 'DM Mono', monospace; color: #9ca3af;"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform duration-300 group-hover:-translate-x-0.5">
        <path d="M12 7H2M6 3L2 7l4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      BACK TO BLOG
    </a>

    <!-- ── 文章 Header ────────────────────────────────────── -->
    <header class="mb-14" style="animation: fadeUp 0.5s ease both;">

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-5">
        {tags.map(tag => (
          <span
            class="px-2.5 py-0.5 text-[10px] font-mono tracking-widest rounded uppercase"
            style="
              background: rgba(8,145,178,0.06);
              border: 1px solid rgba(8,145,178,0.15);
              color: #0891b2;
            "
          >
            {tag}
          </span>
        ))}
      </div>

      <!-- Title -->
      <h1
        class="text-2xl sm:text-3xl md:text-4xl font-bold leading-tight tracking-wide mb-6"
        style="color: #111827;"
      >
        {title}
      </h1>

      <!-- Meta: date + read time -->
      <div class="flex flex-wrap items-center gap-4 text-xs tracking-widest" style="font-family: 'DM Mono', monospace; color: #9ca3af;">
        <span class="flex items-center gap-1.5">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <rect x="1" y="2" width="10" height="9" rx="1.5" stroke="currentColor" stroke-width="1.1"/>
            <path d="M4 1v2M8 1v2M1 5h10" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
          </svg>
          <time datetime={post.created_at}>{formattedDate}</time>
        </span>
        {readTime && (
          <span class="flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.1"/>
              <path d="M6 3.5V6l1.5 1.5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
            </svg>
            {readTime}
          </span>
        )}
      </div>

      <!-- Divider with subtle glow -->
      <div
        class="mt-8 h-px w-full"
        style="background: linear-gradient(to right, #0891b2, #e5e7eb 60%, transparent);"
      ></div>
    </header>

    <!-- ── 文章正文 ─────────────────────────────────────────
         prose-invert: 深色背景适配
         prose-cyan:   链接、粗体使用 cyan 色调
         max-w-none:   宽度由外层容器控制，prose 本身不限制
    ─────────────────────────────────────────────────────── -->
    <div class="prose prose-gray max-w-none article-content" style="color: #374151;">
      <Fragment set:html={htmlContent} />
    </div>

    <!-- ── 文章底部签名 ───────────────────────────────────── -->
    <footer class="mt-20 pt-8" style="border-top: 1px solid #f3f4f6;">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">

        <!-- Tags again (bottom) -->
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <a
              href={`/blog?tag=${tag}`}
              class="px-2.5 py-0.5 text-[10px] font-mono tracking-widest rounded uppercase transition-all duration-300 hover:-translate-y-0.5"
              style="
                background: #f3f4f6;
                border: 1px solid #e5e7eb;
                color: #6b7280;
              "
            >
              # {tag}
            </a>
          ))}
        </div>

        <!-- Back to top -->
        <button
          onclick="window.scrollTo({top:0,behavior:'smooth'})"
          class="flex items-center gap-2 text-xs transition-colors duration-300 tracking-widest group"
          style="font-family: 'DM Mono', monospace; color: #9ca3af;"
        >
          BACK TO TOP
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform duration-300 group-hover:-translate-y-0.5">
            <path d="M6 10V2M2 6l4-4 4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

      </div>
    </footer>

  </article>

    <!-- ── 右侧：同类文章 ─────────────────────────────────── -->
    <aside class="article-rail">
      <div class="rail-panel" id="relatedRail" data-slug={slug} data-tags={JSON.stringify(tags)}>
        <p class="rail-label" id="railLabel">同类文章</p>
        <div id="relatedList" class="rail-list">
          <p class="rail-empty">加载中…</p>
        </div>
      </div>
    </aside>

  </div>
</Layout>

<style>
  /* ── 两栏布局 ──────────────────────────────────────────── */
  .article-layout {
    max-width: 1080px;
    margin: 0 auto;
    padding: 80px 24px;
    display: flex;
    gap: 48px;
    align-items: flex-start;
  }
  .article-main { flex: 1; min-width: 0; max-width: 720px; }
  .article-rail {
    width: 240px;
    flex-shrink: 0;
    position: sticky;
    top: 90px;
  }
  .rail-panel {
    padding: 0;
  }
  .rail-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #9ca3af;
    margin-bottom: 14px;
    padding-left: 2px;
  }
  .rail-list { display: flex; flex-direction: column; gap: 8px; }
  /* 这些卡片由客户端 JS 动态生成，必须用 :global 才能命中 */
  :global(.rail-item) {
    position: relative;
    display: block;
    padding: 12px 14px;
    border-radius: 10px;
    font-size: 13px;
    line-height: 1.55;
    color: #4b5563;
    text-decoration: none;
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid #eceef0;
    box-shadow: 0 3px 14px rgba(8,145,178,0.06);
    transition: all 0.2s cubic-bezier(.16,1,.3,1);
  }
  :global(.rail-item:hover) {
    color: #0891b2;
    border-color: rgba(8,145,178,0.25);
    box-shadow: 0 6px 18px rgba(8,145,178,0.1);
    transform: translateX(3px);
  }
  :global(.rail-item.current) {
    background: rgba(8,145,178,0.1);
    border-color: rgba(8,145,178,0.3);
    color: #0e7490;
    font-weight: 600;
    cursor: default;
    padding-left: 16px;
  }
  :global(.rail-item.current)::before {
    content: '';
    position: absolute;
    left: 0; top: 10px; bottom: 10px;
    width: 3px; border-radius: 0 3px 3px 0;
    background: linear-gradient(to bottom, #22d3ee, #0891b2);
  }
  :global(.rail-item.current)::after {
    content: '阅读中';
    display: inline-block;
    margin-left: 6px;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    color: #0891b2;
    background: rgba(8,145,178,0.12);
    padding: 1px 6px;
    border-radius: 99px;
    vertical-align: middle;
  }
  :global(.rail-empty) {
    font-size: 12px;
    color: #cbd5e1;
    font-family: 'DM Mono', monospace;
    padding: 6px 4px;
  }
  @media (max-width: 900px) {
    .article-layout { display: block; padding: 60px 24px; }
    .article-main { max-width: 720px; margin: 0 auto; }
    .article-rail { display: none; }
  }

  /* ── 页面入场动画 ──────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .article-content {
    animation: fadeUp 0.6s ease 0.15s both;
  }

  /* ── Shiki 代码块额外增强 ─────────────────────────────── */
  .article-content :global(pre) {
    position: relative;
    overflow-x: auto;
  }

  /* 代码块内选中：深底配亮色，保证可读 */
  .article-content :global(pre)::selection,
  .article-content :global(pre *)::selection {
    background: rgba(34,211,238,0.35);
    color: #ffffff;
  }

  /* 行内代码（非代码块内）——浅色背景下清晰可读 */
  .article-content :global(:not(pre) > code) {
    font-family: 'DM Mono', monospace;
    font-size: 0.86em;
    padding: 0.12em 0.42em;
    border-radius: 5px;
    background: rgba(8,145,178,0.07);
    border: 1px solid rgba(8,145,178,0.16);
    color: #0e7490;
    white-space: nowrap;
  }
  .article-content :global(:not(pre) > code)::before,
  .article-content :global(:not(pre) > code)::after { content: none; }

  /* 代码块语言标签 */
  .article-content :global(pre[data-language])::before {
    content:       attr(data-language);
    position:      absolute;
    top:           0.6rem;
    right:         1rem;
    font-size:     10px;
    font-family:   'DM Mono', monospace;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:         rgba(34,211,238,0.45);
    pointer-events:none;
  }

  /* 表格 */
  .article-content :global(table) {
    border-collapse: separate;
    border-spacing:  0;
    border:          1px solid rgba(8,145,178,0.15);
    border-radius:   8px;
    overflow:        hidden;
    width:           100%;
  }
  .article-content :global(thead tr) {
    background: rgba(8,145,178,0.06);
  }
  .article-content :global(th),
  .article-content :global(td) {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid rgba(8,145,178,0.08);
  }

  /* View Transition：文章标题跨页动画 */
  h1 { view-transition-name: article-title; }
</style>

<script is:inline>
  (function() {
    var rail = document.getElementById('relatedRail');
    if (!rail) return;
    var listEl = document.getElementById('relatedList');
    var labelEl = document.getElementById('railLabel');
    var API = window.__DSS_API;
    var curSlug = rail.dataset.slug;
    var tags = [];
    try { tags = JSON.parse(rail.dataset.tags || '[]'); } catch (e) {}

    var CATEGORIES = ['技术手记','生活漫笔','市场观察','山河远阔','读书札记','随想杂谈'];
    var category = null;
    for (var i = 0; i < tags.length; i++) {
      if (CATEGORIES.indexOf(tags[i]) !== -1) { category = tags[i]; break; }
    }
    if (labelEl) labelEl.textContent = category || '更多文章';

    if (!window.__dss_isLoggedIn || !window.__dss_isLoggedIn()) {
      listEl.innerHTML = '<p class="rail-empty">登录后查看</p>';
      return;
    }

    function esc(s) {
      return String(s == null ? '' : s).replace(/[&<>"]/g, function(c) {
        return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[c];
      });
    }

    fetch(API + '/api/posts?page=1&size=100', {
      headers: { 'Authorization': 'Bearer ' + window.__dss_getToken() }
    }).then(function(r) { return r.json(); }).then(function(data) {
      var items = (data && data.items) || [];
      // Filter to same category (if known); always keep current
      var list = items.filter(function(p) {
        if (p.slug === curSlug) return true;
        if (!category) return true;
        return (p.tags || []).indexOf(category) !== -1;
      });
      if (list.length <= 1) {
        listEl.innerHTML = '<p class="rail-empty">暂无同类文章</p>';
        return;
      }
      listEl.innerHTML = list.map(function(p) {
        if (p.slug === curSlug) {
          return '<span class="rail-item current">' + esc(p.title) + '</span>';
        }
        return '<a class="rail-item" href="/blog/' + esc(p.slug) + '">' + esc(p.title) + '</a>';
      }).join('');
    }).catch(function() {
      listEl.innerHTML = '<p class="rail-empty">加载失败</p>';
    });
  })();
</script>
