---
import Layout from '../layouts/Layout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let moments: any[] = [];

const cookieHeader = Astro.request.headers.get('cookie') || '';
const tokenMatch = cookieHeader.match(/dss_token=([^;]+)/);
const stoken = tokenMatch ? tokenMatch[1] : '';
const fetchHeaders: Record<string,string> = {};
if (stoken) fetchHeaders['Authorization'] = 'Bearer ' + stoken;

try {
  const res = await fetch(`${API_URL}/api/moments?page=1&size=50`, { headers: fetchHeaders });
  const data = await res.json();
  moments = (data.items || []).map((m: any) => ({
    id:   String(m.id).padStart(3, '0'),
    rawId: m.id,
    time: m.created_at?.replace('T', ' ').slice(0, 16) || '',
    text: m.text,
    mood: m.mood || '💬',
  }));
} catch (e) {
  console.error('Failed to fetch moments:', e);
}

const moods = ['⚡', '🛸', '💡', '🔧', '📡', '☕', '🌙', '📦', '🔒', '〰️'];
---

<Layout title="碎片记录 · DSS">
  <section class="max-w-3xl mx-auto px-6 py-20">

    <div class="flex items-end justify-between mb-8">
      <div>
        <p class="text-xs tracking-[0.25em] uppercase mb-2" style="font-family: 'DM Mono', monospace; color: #d1d5db;">Moments</p>
        <h1 class="text-3xl font-bold tracking-wide" style="color: #111827;">
          碎片记录
          <span class="inline-block w-1.5 h-1.5 rounded-full mb-1 ml-2 align-middle" style="background: #0891b2;"></span>
        </h1>
      </div>
      <button
        id="toggleForm"
        class="inline-flex items-center gap-2 px-4 py-2 text-xs tracking-widest rounded-md transition-all duration-200 hover:-translate-y-0.5"
        style="font-family: 'DM Mono', monospace; color: #fff; background: #0891b2; border: none; cursor: pointer;"
      >
        + 记一条
      </button>
    </div>

    <!-- Inline compose form -->
    <div id="composeForm" class="hidden mb-10 rounded-lg p-5 transition-all" style="background: #fff; border: 1px solid rgba(8,145,178,0.2);">
      <div class="flex gap-2 mb-3 flex-wrap">
        {moods.map(m => (
          <button class="mood-btn text-lg px-1.5 py-0.5 rounded opacity-30 hover:opacity-100 transition-opacity" data-mood={m} style="cursor:pointer; background:none; border:none;">{m}</button>
        ))}
      </div>
      <textarea
        id="momentText"
        placeholder="记录此刻的想法..."
        rows="3"
        class="w-full rounded-md p-3 text-sm outline-none resize-vertical"
        style="background: #fafafa; border: 1px solid #e5e7eb; color: #374151; line-height: 1.7;"
      ></textarea>
      <div class="flex items-center justify-between mt-3">
        <span id="charCount" class="text-[11px]" style="font-family: 'DM Mono', monospace; color: #d1d5db;">0 字</span>
        <div class="flex gap-2">
          <button id="cancelBtn" class="px-4 py-1.5 text-xs rounded-md" style="font-family: 'DM Mono', monospace; color: #9ca3af; background: none; border: 1px solid #e5e7eb; cursor: pointer;">取消</button>
          <button id="publishBtn" class="px-4 py-1.5 text-xs rounded-md" style="font-family: 'DM Mono', monospace; color: #fff; background: #0891b2; border: none; cursor: pointer;">发布</button>
        </div>
      </div>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <div
        class="absolute left-[19px] top-0 bottom-0 w-px"
        style="background: linear-gradient(to bottom, #d1d5db, #f3f4f6 80%, transparent);"
        aria-hidden="true"
      ></div>

      {moments.length > 0 ? (
        <ul class="space-y-0 list-none m-0 p-0">
          {moments.map((moment: any) => (
            <li class="moment-item relative pl-14 pb-10 group">
              <div class="moment-dot absolute left-0 top-1 w-[38px] h-[38px] flex items-center justify-center rounded-full text-base transition-all duration-300" style="background: #fafafa; border: 1px solid #e5e7eb;">
                {moment.mood}
              </div>
              <div class="moment-card rounded-lg p-5 transition-all duration-300" style="background: #fff; border: 1px solid #e5e7eb;">
                <div class="flex items-center justify-between mb-2.5">
                  <time datetime={moment.time} class="text-[11px] tracking-widest" style="font-family: 'DM Mono', monospace; color: #d1d5db;">
                    {moment.time}
                    <span class="ml-2" style="color: #e5e7eb;">#{moment.id}</span>
                  </time>
                  <button class="del-btn opacity-0 group-hover:opacity-100 transition-opacity text-[11px] px-2 py-0.5 rounded" data-id={moment.rawId} style="font-family: 'DM Mono', monospace; color: #d1d5db; background: none; border: none; cursor: pointer;">
                    删除
                  </button>
                </div>
                <p class="text-sm leading-relaxed" style="color: #6b7280;">{moment.text}</p>
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-sm text-center py-20" style="color: #d1d5db; font-family: 'DM Mono', monospace;">暂无碎片记录</p>
      )}
    </div>

  </section>
</Layout>

<style>
  .moment-item:hover .moment-dot { border-color: rgba(8,145,178,0.3) !important; box-shadow: 0 0 10px rgba(8,145,178,0.08); }
  .moment-item:hover .moment-card { border-color: rgba(8,145,178,0.15) !important; box-shadow: 0 4px 16px rgba(0,0,0,0.04); transform: translateX(3px); }
  .del-btn:hover { color: #ef4444 !important; }
  .mood-btn.active { opacity: 1 !important; background: rgba(8,145,178,0.08) !important; }
</style>

<script is:inline>
  // Auth gate
  if (!window.__dss_isLoggedIn || !window.__dss_isLoggedIn()) {
    document.querySelector('section').innerHTML = '<div style="text-align:center;padding:100px 0;color:#9ca3af;"><p style="font-size:16px;margin-bottom:12px;">需要登录后访问</p><button onclick="window.__dss_toggleLogin()" style="padding:8px 20px;background:#0891b2;color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:13px;">登录</button></div>';
  }

  var API = window.__DSS_API;
  var selectedMood = '⚡';

  function getToken() {
    return Promise.resolve(window.__dss_getToken ? window.__dss_getToken() : '');
  }

  // Reload moments with user's own data
  if (window.__dss_isLoggedIn && window.__dss_isLoggedIn()) {
    // Moments data is server-rendered with public API (empty for non-admin)
    // Client-side fetch user's own moments
    fetch(API + '/api/moments?page=1&size=50', {
      headers: { 'Authorization': 'Bearer ' + window.__dss_getToken() }
    }).then(function(r) { return r.json(); }).then(function(data) {
      // Page will work with existing data for admin, for other users we'd need to re-render
      // For now the server-rendered data works for admin
    });
  }

  // (rest of script below uses getToken() which now returns the stored token)
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password: 'admin123' })
    });
    const data = await res.json();
    token = data.token;
    return token;
  }

  // Toggle form
  const form = document.getElementById('composeForm')!;
  const toggleBtn = document.getElementById('toggleForm')!;
  const cancelBtn = document.getElementById('cancelBtn')!;
  const publishBtn = document.getElementById('publishBtn')!;
  const textarea = document.getElementById('momentText') as HTMLTextAreaElement;
  const charCount = document.getElementById('charCount')!;

  toggleBtn.addEventListener('click', () => {
    form.classList.toggle('hidden');
    if (!form.classList.contains('hidden')) textarea.focus();
  });
  cancelBtn.addEventListener('click', () => form.classList.add('hidden'));

  textarea.addEventListener('input', () => {
    charCount.textContent = `${textarea.value.length} 字`;
  });

  // Mood selection
  document.querySelectorAll('.mood-btn').forEach(btn => {
    if ((btn as HTMLElement).dataset.mood === selectedMood) btn.classList.add('active');
    btn.addEventListener('click', () => {
      document.querySelectorAll('.mood-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedMood = (btn as HTMLElement).dataset.mood || '⚡';
    });
  });

  // Publish
  publishBtn.addEventListener('click', async () => {
    const text = textarea.value.trim();
    if (!text) return;
    publishBtn.textContent = '发布中...';
    try {
      const t = await getToken();
      await fetch(`${API}/api/admin/moments`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${t}` },
        body: JSON.stringify({ text, mood: selectedMood, images: [] })
      });
      location.reload();
    } catch (e) {
      alert('发布失败');
      publishBtn.textContent = '发布';
    }
  });

  // Delete
  document.querySelectorAll('.del-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('确认删除？')) return;
      const id = (btn as HTMLElement).dataset.id;
      const t = await getToken();
      await fetch(`${API}/api/admin/moments/${id}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${t}` }
      });
      location.reload();
    });
  });
</script>
