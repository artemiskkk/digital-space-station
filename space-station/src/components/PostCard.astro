---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  tags: string[];
  slug: string;
  readTime: string;
}
const { title, excerpt, date, tags, slug, readTime } = Astro.props;
---

<a
  href={`/blog/${slug}`}
  class="post-card group block rounded-lg p-6 transition-all duration-300 no-underline"
  style="background: #fff; border: 1px solid #e5e7eb;"
>
  <div class="flex flex-wrap gap-2 mb-4">
    {tags.map(tag => (
      <span
        class="px-2 py-0.5 text-[10px] font-mono tracking-widest rounded uppercase"
        style="background: rgba(8,145,178,0.06); border: 1px solid rgba(8,145,178,0.15); color: #0891b2;"
      >
        {tag}
      </span>
    ))}
  </div>

  <h3 class="text-base sm:text-lg font-semibold mb-2.5 leading-snug tracking-wide transition-colors duration-300" style="color: #111827;">
    {title}
  </h3>

  <p class="text-sm leading-relaxed mb-5 line-clamp-2" style="color: #9ca3af;">
    {excerpt}
  </p>

  <div class="flex items-center justify-between text-[11px] tracking-wider" style="color: #d1d5db; font-family: 'DM Mono', monospace;">
    <time datetime={date}>{date}</time>
    <span class="flex items-center gap-1.5 transition-colors duration-300 group-hover:text-gray-500">
      {readTime}
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="transition-transform duration-300 group-hover:translate-x-0.5">
        <path d="M1 5h8M5.5 1.5l3.5 3.5-3.5 3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</a>

<style>
  .post-card:hover {
    transform: translateY(-3px);
    border-color: rgba(8,145,178,0.25) !important;
    box-shadow: 0 8px 30px rgba(0,0,0,0.06), 0 0 0 1px rgba(8,145,178,0.08);
  }
</style>
