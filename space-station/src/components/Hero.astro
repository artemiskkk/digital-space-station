---
// Hero — dark cinematic section with an abstract fluid sculpture visual,
// transitioning into the light content below.
---

<section class="hero js-dark-hero">

  <!-- Sculpture visual (dark, with its own particles) -->
  <div class="hero-visual" aria-hidden="true">
    <img src="/hero.png" alt="" loading="eager" decoding="async" />
  </div>

  <!-- Vignette + readability scrim -->
  <div class="hero-scrim" aria-hidden="true"></div>
  <!-- Fade into the light content below -->
  <div class="hero-fade" aria-hidden="true"></div>

  <div class="hero-content">

    <h1 class="hero-title">
      <span class="hero-title-line">DIGITAL&nbsp;SPACE</span>
    </h1>

    <div class="hero-sub">
      <span class="hero-prompt">~/artemis $&nbsp;</span>
      <span>探索 · 记录 · 代码</span>
      <span class="hero-caret"></span>
    </div>

    <p class="hero-desc">
      这里是我的数字据点 —— 记录硬件与嵌入式的探索历程、零散的技术思考，<br class="hidden sm:block" />
      以及一些值得被留存的碎片。
    </p>

    <div class="hero-actions">
      <a href="/blog" class="hero-btn hero-btn-primary">
        读博客
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

  </div>

  <div class="hero-scroll" aria-hidden="true">
    <span>SCROLL</span>
    <div class="hero-scroll-line"></div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    margin-top: -3.5rem; /* pull under the fixed nav (cancels main's pt-14) */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #050506;
  }

  .hero-visual {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-visual img {
    width: min(88vw, 1080px);
    height: auto;
    object-fit: contain;
    transform: translateY(-10%);
    animation: heroVisualFloat 14s ease-in-out infinite;
    -webkit-mask-image: radial-gradient(ellipse 68% 64% at 50% 46%, #000 46%, transparent 82%);
    mask-image: radial-gradient(ellipse 68% 64% at 50% 46%, #000 46%, transparent 82%);
  }
  @keyframes heroVisualFloat {
    0%, 100% { transform: translateY(-10%) scale(1); }
    50%      { transform: translateY(calc(-10% - 12px)) scale(1.03); }
  }

  /* Darken edges + lower-center for white-text readability */
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse 65% 55% at 50% 72%, rgba(5,5,6,0.45) 0%, transparent 62%),
      linear-gradient(to bottom, rgba(5,5,6,0.85) 0%, rgba(5,5,6,0.3) 12%, transparent 26%, transparent 100%);
    pointer-events: none;
  }
  .hero-fade {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 200px;
    z-index: 1;
    background: linear-gradient(to bottom,
      transparent 0%,
      transparent 55%,
      rgba(250,250,250,0.15) 74%,
      rgba(250,250,250,0.6) 90%,
      #fafafa 100%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 24px;
    max-width: 900px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 14px;
    border-radius: 99px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255,255,255,0.14);
    margin-bottom: 34px;
    opacity: 0;
    animation: heroFade 0.7s ease 0.1s forwards;
  }
  .hero-badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #22d3ee;
    box-shadow: 0 0 0 0 rgba(34,211,238,0.5);
    animation: heroPulse 2s infinite;
  }

  .hero-title {
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: 0.05em;
    margin: 0 0 26px;
    display: flex;
    justify-content: center;
  }
  .hero-title-line {
    font-size: clamp(38px, 8vw, 96px);
    color: #ffffff;
    white-space: nowrap;
    text-shadow: 0 2px 40px rgba(0,0,0,0.5);
    opacity: 0;
    transform: translateY(24px);
    animation: heroRise 0.9s cubic-bezier(.16,1,.3,1) 0.2s forwards;
  }
  .hero-title-accent {
    background: linear-gradient(135deg, #22d3ee 0%, #67e8f9 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-sub {
    font-family: 'DM Mono', monospace;
    font-size: clamp(14px, 2vw, 17px);
    letter-spacing: 0.05em;
    margin-bottom: 26px;
    opacity: 0;
    animation: heroFade 0.7s ease 0.55s forwards;
  }
  .hero-prompt { color: rgba(255,255,255,0.4); }
  .hero-sub > span:nth-child(2) { color: rgba(255,255,255,0.78); }
  .hero-caret {
    display: inline-block;
    width: 2px; height: 1.05em;
    margin-left: 3px;
    vertical-align: middle;
    background: #22d3ee;
    animation: heroBlink 1.1s step-end infinite;
  }

  .hero-desc {
    max-width: 540px;
    margin: 0 auto 38px;
    font-size: 14px;
    line-height: 1.85;
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.55);
    opacity: 0;
    animation: heroFade 0.7s ease 0.7s forwards;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    opacity: 0;
    animation: heroFade 0.7s ease 0.85s forwards;
  }
  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 30px;
    border-radius: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(.16,1,.3,1);
  }
  .hero-btn-primary {
    color: rgba(255,255,255,0.92);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.4);
    padding: 16px 46px;
    font-size: 14px;
    backdrop-filter: blur(4px);
  }
  .hero-btn-primary:hover {
    transform: translateY(-2px);
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.75);
  }

  .hero-scroll {
    position: absolute;
    bottom: 26px; left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.3em;
    color: rgba(255,255,255,0.4);
    opacity: 0;
    animation: heroFade 1s ease 1.1s forwards;
  }
  .hero-scroll-line {
    width: 1px; height: 34px;
    background: linear-gradient(to bottom, #22d3ee, transparent);
    animation: heroScroll 2s ease-in-out infinite;
    transform-origin: top;
  }

  @keyframes heroFade { to { opacity: 1; } }
  @keyframes heroRise { to { opacity: 1; transform: translateY(0); } }
  @keyframes heroBlink { 0%,100%{opacity:1} 50%{opacity:0} }
  @keyframes heroPulse {
    0%   { box-shadow: 0 0 0 0 rgba(34,211,238,0.5); }
    70%  { box-shadow: 0 0 0 7px rgba(34,211,238,0); }
    100% { box-shadow: 0 0 0 0 rgba(34,211,238,0); }
  }
  @keyframes heroScroll {
    0%,100% { transform: scaleY(0.4); opacity: 0.4; }
    50%     { transform: scaleY(1); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-visual img { animation: none; }
  }
</style>
