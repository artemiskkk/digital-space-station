---
// Hero — cinematic landscape photo background, framed, with DIGITAL SPACE title.
---

<section class="hero js-dark-hero">

  <!-- Landscape photo background -->
  <div class="hero-bg" aria-hidden="true"></div>
  <!-- Cursor spotlight (brightens where the mouse hovers) -->
  <div class="hero-light" aria-hidden="true"></div>
  <!-- Dark gradient for text legibility -->
  <div class="hero-scrim" aria-hidden="true"></div>
  <!-- Fade into the light content below -->
  <div class="hero-fade" aria-hidden="true"></div>

  <div class="hero-content">

    <h1 class="hero-title">
      <span class="hero-title-line">DIGITAL&nbsp;<span class="hero-title-accent">SPACE</span></span>
    </h1>

    <div class="hero-sub">
      <span class="hero-prompt">~/artemis $&nbsp;</span>
      <span>探索 · 记录 · 代码</span>
      <span class="hero-caret"></span>
    </div>

    <p class="hero-desc">
      这里是我的数字据点 —— 记录硬件与嵌入式的探索历程、零散的技术思考，<br class="hidden sm:block" />
      以及一些值得被留存的碎片。
    </p>

    <div class="hero-actions">
      <a href="/blog" class="hero-btn hero-btn-primary">
        读博客
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

  </div>

  <div class="hero-scroll" aria-hidden="true">
    <span>SCROLL</span>
    <div class="hero-scroll-line"></div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    margin-top: -3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0c1116;
  }

  .hero-bg {
    position: absolute;
    inset: -24px;               /* extra room so parallax never reveals edges */
    z-index: 0;
    background: url('/hero-bg.jpg') center 42% / cover no-repeat;
    transform: scale(1.06);
    transition: transform 0.45s cubic-bezier(.16,1,.3,1), filter 0.45s ease;
    will-change: transform;
  }

  /* Cursor spotlight */
  .hero-light {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.45s ease;
    background: radial-gradient(circle 320px at var(--mx, 50%) var(--my, 50%), rgba(255,255,255,0.20), transparent 62%);
    mix-blend-mode: screen;
  }
  .hero.is-hover .hero-light { opacity: 1; }

  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(to bottom, rgba(12,17,22,0.55) 0%, rgba(12,17,22,0.15) 22%, rgba(12,17,22,0.15) 50%, rgba(12,17,22,0.45) 100%),
      radial-gradient(ellipse 80% 60% at 50% 52%, rgba(12,17,22,0.35) 0%, transparent 70%);
  }
  .hero-fade {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 200px;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent 0%, transparent 55%, rgba(250,250,250,0.15) 74%, rgba(250,250,250,0.6) 90%, #fafafa 100%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 24px;
    max-width: 900px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 14px;
    border-radius: 99px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.82);
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255,255,255,0.18);
    margin-bottom: 30px;
    opacity: 0;
    animation: heroFade 0.7s ease 0.1s forwards;
  }
  .hero-badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #22d3ee;
    box-shadow: 0 0 0 0 rgba(34,211,238,0.5);
    animation: heroPulse 2s infinite;
  }

  .hero-title {
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: 0.05em;
    margin: 0 0 24px;
    display: flex;
    justify-content: center;
  }
  .hero-title-line {
    font-size: clamp(44px, 9vw, 104px);
    color: #ffffff;
    white-space: nowrap;
    text-shadow: 0 4px 40px rgba(0,0,0,0.55);
    opacity: 0;
    transform: translateY(24px);
    animation: heroRise 0.9s cubic-bezier(.16,1,.3,1) 0.2s forwards;
  }
  .hero-title-accent {
    background: linear-gradient(135deg, #22d3ee 0%, #67e8f9 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-sub {
    font-family: 'DM Mono', monospace;
    font-size: clamp(14px, 2vw, 17px);
    letter-spacing: 0.05em;
    margin-bottom: 24px;
    text-shadow: 0 2px 16px rgba(0,0,0,0.5);
    opacity: 0;
    animation: heroFade 0.7s ease 0.55s forwards;
  }
  .hero-prompt { color: rgba(255,255,255,0.5); }
  .hero-sub > span:nth-child(2) { color: rgba(255,255,255,0.9); }
  .hero-caret {
    display: inline-block;
    width: 2px; height: 1.05em;
    margin-left: 3px;
    vertical-align: middle;
    background: #22d3ee;
    animation: heroBlink 1.1s step-end infinite;
  }

  .hero-desc {
    max-width: 540px;
    margin: 0 auto 36px;
    font-size: 14px;
    line-height: 1.85;
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.7);
    text-shadow: 0 2px 14px rgba(0,0,0,0.5);
    opacity: 0;
    animation: heroFade 0.7s ease 0.7s forwards;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    opacity: 0;
    animation: heroFade 0.7s ease 0.85s forwards;
  }
  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 36px;
    border-radius: 9px;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: all 0.25s cubic-bezier(.16,1,.3,1);
  }
  .hero-btn-primary {
    color: rgba(255,255,255,0.92);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.4);
    backdrop-filter: blur(6px);
  }
  .hero-btn-primary:hover {
    transform: translateY(-2px);
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.75);
  }

  .hero-scroll {
    position: absolute;
    bottom: 26px; left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.3em;
    color: rgba(255,255,255,0.55);
    opacity: 0;
    animation: heroFade 1s ease 1.1s forwards;
  }
  .hero-scroll-line {
    width: 1px; height: 34px;
    background: linear-gradient(to bottom, #22d3ee, transparent);
    animation: heroScroll 2s ease-in-out infinite;
    transform-origin: top;
  }

  @keyframes heroFade { to { opacity: 1; } }
  @keyframes heroRise { to { opacity: 1; transform: translateY(0); } }
  @keyframes heroBlink { 0%,100%{opacity:1} 50%{opacity:0} }
  @keyframes heroPulse {
    0%   { box-shadow: 0 0 0 0 rgba(34,211,238,0.5); }
    70%  { box-shadow: 0 0 0 7px rgba(34,211,238,0); }
    100% { box-shadow: 0 0 0 0 rgba(34,211,238,0); }
  }
  @keyframes heroScroll {
    0%,100% { transform: scaleY(0.4); opacity: 0.4; }
    50%     { transform: scaleY(1); opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg { transition: none; }
    .hero-light { display: none; }
  }
</style>

<script is:inline>
  (function() {
    var hero = document.querySelector('.hero.js-dark-hero');
    if (!hero) return;
    var bg = hero.querySelector('.hero-bg');
    var light = hero.querySelector('.hero-light');
    if (!bg) return;
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var raf = null, tx = 0, ty = 0, cx = 0, cy = 0;
    function render() {
      cx += (tx - cx) * 0.12;
      cy += (ty - cy) * 0.12;
      bg.style.transform = 'scale(1.09) translate(' + cx + 'px,' + cy + 'px)';
      if (Math.abs(tx - cx) > 0.1 || Math.abs(ty - cy) > 0.1) {
        raf = requestAnimationFrame(render);
      } else { raf = null; }
    }
    function kick() { if (!raf) raf = requestAnimationFrame(render); }

    hero.addEventListener('mousemove', function(e) {
      var r = hero.getBoundingClientRect();
      var mx = (e.clientX - r.left) / r.width;
      var my = (e.clientY - r.top) / r.height;
      tx = (mx - 0.5) * -22;   // parallax shift (px)
      ty = (my - 0.5) * -22;
      bg.style.filter = 'brightness(1.08)';
      hero.classList.add('is-hover');
      if (light) {
        light.style.setProperty('--mx', (mx * 100) + '%');
        light.style.setProperty('--my', (my * 100) + '%');
      }
      kick();
    });
    hero.addEventListener('mouseleave', function() {
      tx = 0; ty = 0;
      bg.style.filter = '';
      hero.classList.remove('is-hover');
      kick();
    });
  })();
</script>
