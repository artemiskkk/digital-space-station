---
// DSS Companion — astronaut red-panda mascot: floats in the corner,
// blinks/glances now and then, speaks in bubbles, draggable.
---

<div id="dssCompanion" class="companion" aria-hidden="true">
  <!-- Speech bubble -->
  <div id="companionBubble" class="companion-bubble"></div>

  <!-- Mascot (two stacked imgs for cross-fade between frames) -->
  <div id="companionBody" class="companion-body">
    <div class="companion-shadow"></div>
    <div id="companionFrames" class="companion-frames">
      <img src="/companion/idle.png" alt="" class="companion-img" id="companionMain" draggable="false" />
      <img src="/companion/idle.png" alt="" class="companion-img companion-ghost" id="companionGhost" draggable="false" />
    </div>
  </div>
</div>

<style>
  .companion {
    position: fixed;
    right: 26px;
    bottom: 18px;
    z-index: 90;
    width: 104px;
    height: 132px;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    touch-action: none;
  }
  .companion.dragging { cursor: grabbing; }
  .companion.hidden { display: none; }

  .companion-body {
    position: relative;
    width: 100%;
    height: 100%;
    animation: companionFloat 4s ease-in-out infinite;
    transform-origin: center bottom;
  }
  .companion.dragging .companion-body { animation: none; }
  .companion.poke .companion-body { animation: companionPoke 0.55s cubic-bezier(.36,.07,.19,.97); }

  .companion-frames {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
  }

  .companion-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 6px 10px rgba(0,0,0,0.22));
    pointer-events: none;
  }
  .companion-ghost {
    opacity: 0;
    z-index: 2;
  }

  .companion-shadow {
    position: absolute;
    left: 50%; bottom: 2px;
    transform: translateX(-50%);
    width: 62px; height: 10px;
    border-radius: 50%;
    background: rgba(8,145,178,0.22);
    filter: blur(4px);
    animation: companionShadow 4s ease-in-out infinite;
  }

  @keyframes companionFloat {
    0%, 100% { transform: translateY(0) rotate(-1.5deg); }
    50%      { transform: translateY(-9px) rotate(1.5deg); }
  }
  @keyframes companionShadow {
    0%, 100% { opacity: 0.5; transform: translateX(-50%) scale(1); }
    50%      { opacity: 0.25; transform: translateX(-50%) scale(0.8); }
  }
  @keyframes companionPoke {
    0%   { transform: translateY(0) scale(1) rotate(0); }
    25%  { transform: translateY(5px) scale(1.06,0.94); }
    55%  { transform: translateY(-9px) scale(0.95,1.05) rotate(5deg); }
    100% { transform: translateY(0) scale(1) rotate(0); }
  }

  /* Speech bubble */
  .companion-bubble {
    position: absolute;
    bottom: 100%;
    right: 4px;
    margin-bottom: 8px;
    max-width: 220px;
    width: max-content;
    padding: 11px 15px;
    background: #fff;
    border: 1px solid rgba(8,145,178,0.22);
    border-radius: 14px;
    font-size: 13px;
    line-height: 1.55;
    color: #374151;
    box-shadow: 0 10px 30px rgba(8,145,178,0.16);
    opacity: 0;
    transform: translateY(8px) scale(0.92);
    transform-origin: bottom right;
    transition: opacity 0.28s ease, transform 0.28s cubic-bezier(.34,1.56,.64,1);
    pointer-events: none;
  }
  .companion-bubble.show { opacity: 1; transform: translateY(0) scale(1); }
  .companion-bubble::after {
    content: '';
    position: absolute;
    bottom: -6px; right: 26px;
    width: 11px; height: 11px;
    background: #fff;
    border-right: 1px solid rgba(8,145,178,0.22);
    border-bottom: 1px solid rgba(8,145,178,0.22);
    transform: rotate(45deg);
  }

  @media (max-width: 640px) {
    .companion { right: 12px; bottom: 12px; transform: scale(0.82); transform-origin: bottom right; }
  }
</style>

<script is:inline>
  (function() {
    var el = document.getElementById('dssCompanion');
    if (!el) return;

    var body = document.getElementById('companionBody');
    var bubble = document.getElementById('companionBubble');
    var img = document.getElementById('companionMain');
    var ghost = document.getElementById('companionGhost');

    // ── Frames (idle life only) ─────────────────────────────
    var F = {
      idle:   '/companion/idle.png',
      blink:  '/companion/blink.png',
      glance: '/companion/glance.png'
    };
    for (var k in F) { var pre = new Image(); pre.src = F[k]; }

    // Cross-fade frame swap: old frame lingers on the ghost layer and fades out
    var curFrame = F.idle;
    function setFrame(src) {
      if (src === curFrame) return;
      ghost.src = curFrame;
      ghost.style.transition = 'none';
      ghost.style.opacity = '1';
      void ghost.offsetWidth;
      ghost.style.transition = 'opacity 110ms linear';
      ghost.style.opacity = '0';
      img.src = src;
      curFrame = src;
    }

    // Blink / glance now and then
    setInterval(function() {
      if (el.classList.contains('dragging')) return;
      var r = Math.random();
      if (r < 0.55) {
        setFrame(F.blink);
        setTimeout(function() { setFrame(F.idle); }, 220);
      } else if (r < 0.8) {
        setFrame(F.glance);
        setTimeout(function() { setFrame(F.idle); }, 900);
      }
    }, 3600);

    // ── Speech ───────────────────────────────────────────────
    var idleLines = [
      '信号良好，轨道稳定 📡',
      '正在巡视数字空间…',
      '检测到访客，欢迎登站',
      '要不要看看最新的博客？',
      '碎片记录里藏着不少灵感',
      '摸摸我试试？',
      '所有系统正常 ✦',
      'DSS 待命中，随时出发 🚀'
    ];
    var pokeLines = ['嗷呜～', '收到指令 ✓', '在的在的！', '别挠我啦 >_<', '需要帮忙吗？', '嘿嘿～'];
    var bubbleTimer = null;

    function say(text, duration) {
      bubble.textContent = text;
      bubble.classList.add('show');
      clearTimeout(bubbleTimer);
      bubbleTimer = setTimeout(function() { bubble.classList.remove('show'); }, duration || 3400);
    }
    function pick(a) { return a[Math.floor(Math.random() * a.length)]; }

    setTimeout(function() { say(idleLines[2]); }, 1200);
    setInterval(function() {
      if (el.classList.contains('dragging')) return;
      if (Math.random() < 0.5) say(pick(idleLines));
    }, 14000);

    body.addEventListener('click', function() {
      if (el._dragged) { el._dragged = false; return; }
      el.classList.remove('poke'); void el.offsetWidth; el.classList.add('poke');
      setFrame(F.blink);           // happy closed-eyes reaction
      setTimeout(function() { setFrame(F.idle); }, 700);
      say(pick(pokeLines), 2000);
    });

    // ── Drag ─────────────────────────────────────────────────
    var startX, startY, originRight, originBottom, moved;
    function onDown(e) {
      var pt = e.touches ? e.touches[0] : e;
      startX = pt.clientX; startY = pt.clientY;
      var rect = el.getBoundingClientRect();
      originRight = window.innerWidth - rect.right;
      originBottom = window.innerHeight - rect.bottom;
      moved = false;
      el.classList.add('dragging');
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
      document.addEventListener('touchmove', onMove, { passive: false });
      document.addEventListener('touchend', onUp);
    }
    function onMove(e) {
      var pt = e.touches ? e.touches[0] : e;
      var dx = pt.clientX - startX, dy = pt.clientY - startY;
      if (Math.abs(dx) > 3 || Math.abs(dy) > 3) moved = true;
      if (e.cancelable) e.preventDefault();
      el.style.right = Math.max(6, originRight - dx) + 'px';
      el.style.bottom = Math.max(6, originBottom - dy) + 'px';
    }
    function onUp() {
      el.classList.remove('dragging');
      el._dragged = moved;
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup', onUp);
      document.removeEventListener('touchmove', onMove);
      document.removeEventListener('touchend', onUp);
    }
    el.addEventListener('mousedown', onDown);
    el.addEventListener('touchstart', onDown, { passive: true });
  })();
</script>
