---
// Moments are private — fetched client-side with the user's token.
---

<section class="max-w-5xl mx-auto px-6 py-20" style="border-top: 1px solid #f3f4f6;">

  <div class="mb-12">
    <p class="text-xs tracking-[0.25em] uppercase mb-2" style="font-family: 'DM Mono', monospace; color: #d1d5db;">Moments</p>
    <h2 class="text-2xl font-bold tracking-wide" style="color: #111827;">
      碎片记录
      <span class="inline-block w-1.5 h-1.5 rounded-full mb-1 ml-2 align-middle" style="background: #0891b2;"></span>
    </h2>
  </div>

  <div class="relative">

    <div
      class="absolute left-[19px] top-0 bottom-0 w-px"
      style="background: linear-gradient(to bottom, #d1d5db, #f3f4f6 80%, transparent);"
      aria-hidden="true"
    ></div>

    <ul id="homeMoments" class="space-y-0 list-none m-0 p-0">
      <p class="text-sm text-center py-16" style="color: #d1d5db; font-family: 'DM Mono', monospace;">
        加载中...
      </p>
    </ul>

    <div class="pl-12 pt-2">
      <a
        href="/moments"
        class="text-xs transition-colors duration-300 tracking-widest flex items-center gap-2 group"
        style="font-family: 'DM Mono', monospace; color: #d1d5db;"
      >
        LOAD MORE
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="transition-transform duration-300 group-hover:translate-y-0.5">
          <path d="M5 1v8M1 6l4 3 4-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .moment-item:hover .moment-dot {
    border-color: rgba(8,145,178,0.3) !important;
    box-shadow: 0 0 10px rgba(8,145,178,0.08);
  }
  .moment-item:hover .moment-card {
    border-color: rgba(8,145,178,0.15) !important;
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
    transform: translateX(3px);
  }
</style>

<script is:inline>
  (function() {
    var box = document.getElementById('homeMoments');
    if (!box) return;
    var API = window.__DSS_API;

    function esc(s) {
      return String(s == null ? '' : s).replace(/[&<>"]/g, function(c) {
        return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[c];
      });
    }

    // Moments require auth; if not logged in, show nothing meaningful
    if (!window.__dss_isLoggedIn || !window.__dss_isLoggedIn()) {
      box.innerHTML = '<p class="text-sm text-center py-16" style="color:#d1d5db;font-family:\'DM Mono\',monospace;">登录后查看碎片记录</p>';
      return;
    }

    fetch(API + '/api/moments?page=1&size=5', {
      headers: { 'Authorization': 'Bearer ' + window.__dss_getToken() }
    }).then(function(r) { return r.json(); }).then(function(data) {
      var items = (data && data.items) || [];
      if (!items.length) {
        box.innerHTML = '<p class="text-sm text-center py-16" style="color:#d1d5db;font-family:\'DM Mono\',monospace;">暂无碎片记录...</p>';
        return;
      }
      box.innerHTML = items.map(function(m) {
        var id = String(m.id).padStart(3, '0');
        var time = (m.created_at || '').replace('T', ' ').slice(0, 16);
        var mood = m.mood || '💬';
        return '<li class="moment-item relative pl-12 pb-10 group">' +
          '<div class="moment-dot absolute left-0 top-1 w-[38px] h-[38px] flex items-center justify-center rounded-full text-base transition-all duration-300" style="background:#fafafa;border:1px solid #e5e7eb;">' + mood + '</div>' +
          '<div class="moment-card rounded-lg p-5 transition-all duration-300" style="background:#fff;border:1px solid #e5e7eb;">' +
          '<time class="block text-[11px] tracking-widest mb-2.5" style="font-family:\'DM Mono\',monospace;color:#d1d5db;">' +
          esc(time) + '<span class="ml-2" style="color:#e5e7eb;">#' + id + '</span></time>' +
          '<p class="text-sm leading-relaxed" style="color:#6b7280;">' + esc(m.text) + '</p>' +
          '</div></li>';
      }).join('');
    }).catch(function() {
      box.innerHTML = '<p class="text-sm text-center py-16" style="color:#d1d5db;font-family:\'DM Mono\',monospace;">加载失败</p>';
    });
  })();
</script>
