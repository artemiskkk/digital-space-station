---
// Recent posts — fetched client-side so the shell renders instantly
// (no blocking on the backend during SSR / cold start).
---

<section class="max-w-5xl mx-auto px-6 py-20">

  <!-- Section Header -->
  <div class="flex items-end justify-between mb-10">
    <div>
      <p class="text-xs tracking-[0.25em] uppercase mb-2" style="font-family: 'DM Mono', monospace; color: #d1d5db;">Recent Posts</p>
      <h2 class="text-2xl font-bold tracking-wide" style="color: #111827;">
        最新文章
        <span class="inline-block w-1.5 h-1.5 rounded-full mb-1 ml-2 align-middle" style="background: #0891b2;"></span>
      </h2>
    </div>
    <a
      href="/blog"
      class="hidden sm:flex items-center gap-2 text-xs transition-colors duration-300 tracking-widest group"
      style="font-family: 'DM Mono', monospace; color: #9ca3af;"
    >
      ALL POSTS
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform duration-300 group-hover:translate-x-0.5">
        <path d="M1 6h10M7 2l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

  <!-- Cards Grid (filled client-side) -->
  <div id="recentPosts" class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <!-- Skeletons -->
    <div class="rp-skeleton"></div>
    <div class="rp-skeleton"></div>
    <div class="rp-skeleton"></div>
  </div>

</section>

<style>
  .rp-skeleton {
    height: 168px;
    border-radius: 8px;
    background: linear-gradient(100deg, #f3f4f6 30%, #fafafa 50%, #f3f4f6 70%);
    background-size: 200% 100%;
    animation: rpShimmer 1.3s ease-in-out infinite;
    border: 1px solid #f3f4f6;
  }
  @keyframes rpShimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
  /* 卡片由客户端 JS 动态生成，必须用 :global 才能命中 */
  :global(.rp-card) {
    display: block;
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255,255,255,0.7);
    border-radius: 12px;
    padding: 24px;
    text-decoration: none;
    box-shadow: 0 4px 18px rgba(8,145,178,0.05);
    transition: all 0.25s cubic-bezier(.16,1,.3,1);
  }
  :global(.rp-card:hover) {
    transform: translateY(-3px);
    border-color: rgba(8,145,178,0.25);
    box-shadow: 0 12px 32px rgba(8,145,178,0.1);
  }
  :global(.rp-tags) { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
  :global(.rp-tag) {
    padding: 2px 8px; font-size: 10px; font-family: 'DM Mono', monospace;
    letter-spacing: 0.1em; border-radius: 4px; text-transform: uppercase;
    background: rgba(8,145,178,0.06); border: 1px solid rgba(8,145,178,0.15); color: #0891b2;
  }
  :global(.rp-title) { font-size: 17px; font-weight: 600; color: #111827; margin: 0 0 10px; line-height: 1.4; }
  :global(.rp-excerpt) { font-size: 14px; color: #9ca3af; line-height: 1.6; margin: 0 0 20px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  :global(.rp-meta) { display: flex; justify-content: space-between; font-size: 11px;
    color: #d1d5db; font-family: 'DM Mono', monospace; letter-spacing: 0.05em; }
  :global(.rp-empty) { grid-column: 1/-1; text-align: center; padding: 64px 0; color: #d1d5db;
    font-family: 'DM Mono', monospace; font-size: 13px; }
</style>

<script is:inline>
  (function() {
    var box = document.getElementById('recentPosts');
    if (!box) return;
    var API = window.__DSS_API;

    function esc(s) {
      return String(s == null ? '' : s).replace(/[&<>"]/g, function(c) {
        return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' }[c];
      });
    }

    fetch(API + '/api/public/posts?page=1&size=3')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var posts = (data && data.items) || [];
        if (!posts.length) {
          box.innerHTML = '<p class="rp-empty">暂无文章，敬请期待...</p>';
          return;
        }
        box.innerHTML = posts.map(function(p) {
          var tags = (p.tags || []).map(function(t) {
            return '<span class="rp-tag">' + esc(t) + '</span>';
          }).join('');
          var date = (p.created_at || '').split('T')[0];
          return '<a class="rp-card" href="/blog/' + esc(p.slug) + '">' +
            '<div class="rp-tags">' + tags + '</div>' +
            '<h3 class="rp-title">' + esc(p.title) + '</h3>' +
            '<p class="rp-excerpt">' + esc(p.excerpt) + '</p>' +
            '<div class="rp-meta"><time>' + esc(date) + '</time><span>' + esc(p.read_time || '') + ' →</span></div>' +
            '</a>';
        }).join('');
      })
      .catch(function() {
        box.innerHTML = '<p class="rp-empty">内容加载中，稍后刷新试试…</p>';
      });
  })();
</script>
