PORT=8080
DATABASE_URL=postgres://user:password@localhost:5432/dss?sslmode=disable

# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key

# Admin login password
ADMIN_PASSWORD=change-me

# Cloudflare R2 (optional, for image hosting)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=dss-media
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# CORS whitelist
FRONTEND_URL=https://your-astro-site.vercel.app
ADMIN_URL=https://your-admin-site.vercel.app
